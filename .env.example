# ============================================
# Stock Briefing Agent - 환경 변수 설정
# ============================================
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env

# Anthropic Claude API Key
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Telegram Bot Token
# @BotFather 에서 봇 생성 후 발급받은 토큰
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram Chat ID (본인의 채팅 ID)
# @userinfobot 에게 메시지를 보내면 확인 가능
TELEGRAM_CHAT_ID=123456789

# 브리핑 스케줄 (HH:MM 형식, KST 기준)
MORNING_BRIEF_TIME=08:00
EVENING_BRIEF_TIME=18:00

# 실시간 모니터링 간격 (분)
MONITOR_INTERVAL_MINUTES=30

# 관심 종목/ETF (콤마로 구분)
WATCHLIST=KODEX 200,TIGER 나스닥100,KODEX 레버리지,TIGER 미국S&P500

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
